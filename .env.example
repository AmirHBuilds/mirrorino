# -----------------------------
# Infrastructure (docker-compose)
# -----------------------------
DB_PASSWORD=change_this_db_password
REDIS_PASSWORD=change_this_redis_password

# -----------------------------
# Frontend
# -----------------------------
NUXT_PUBLIC_API_BASE=https://api.downloadino.com
NUXT_PUBLIC_SUPPORT_EMAIL=support@downloadino.com
NUXT_PUBLIC_SUPPORT_TELEGRAM_ID=@downloadino_support
NUXT_PUBLIC_SUPPORT_WEBSITE=https://downloadino.com

# -----------------------------
# Backend app
# -----------------------------
APP_NAME=Downloadino
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=false
FRONTEND_URL=https://downloadino.com

DATABASE_URL=postgresql+asyncpg://downloadino:change_this_db_password@db:5432/downloadino
REDIS_URL=redis://:change_this_redis_password@redis:6379/0

STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://s3.ir-thr-at1.arvanstorage.ir
S3_ACCESS_KEY=your-arvan-access-key
S3_SECRET_KEY=your-arvan-secret-key
S3_BUCKET_NAME=downloadino-files
S3_REGION=ir-thr-at1
LOCAL_STORAGE_PATH=/data/files

DEFAULT_STORAGE_LIMIT=104857600
VERIFIED_STORAGE_LIMIT=2147483648

ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

MAX_UPLOAD_PER_HOUR=10
MAX_LOGIN_ATTEMPTS_PER_HOUR=5
MAX_DOWNLOADS_PER_HOUR=50

SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@downloadino.ir
SUPERADMIN_PASSWORD=changeme123!
